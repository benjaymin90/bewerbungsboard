generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Multi-Tenancy & Auth (Clerk) ---

model Organization {
  id         String   @id @default(cuid())
  clerkOrgId String   @unique
  name       String
  plan       Plan     @default(FREE)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  jobs      Job[]
  templates EmailTemplate[]
  members   OrgMember[]

  @@map("organizations")
}

model OrgMember {
  id          String   @id @default(cuid())
  clerkUserId String
  orgId       String
  role        OrgRole  @default(RECRUITER)
  createdAt   DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([clerkUserId, orgId])
  @@map("org_members")
}

enum Plan {
  FREE      // 1 Stelle, 10 Bewerber
  STARTER   // 5 Stellen, EUR 19/Mo
  PRO       // unbegrenzt, EUR 49/Mo
}

enum OrgRole {
  ADMIN
  RECRUITER
  VIEWER
}

// --- Jobs (Stellen) ---

model Job {
  id           String       @id @default(cuid())
  orgId        String
  title        String
  description  String       @db.Text
  team         String?
  location     String
  locationType LocationType @default(ON_SITE)
  status       JobStatus    @default(OPEN)
  publishedAt  DateTime?
  closedAt     DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  applicants Applicant[]

  @@index([orgId, status])
  @@map("jobs")
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
}

enum LocationType {
  ON_SITE
  REMOTE
  HYBRID
}

// --- Applicants (Bewerber) ---

model Applicant {
  id              String         @id @default(cuid())
  jobId           String
  firstName       String
  lastName        String
  email           String
  phone           String?
  linkedIn        String?
  salary          String?
  availableFrom   String?
  skills          String[]
  score           Int?
  stage           ApplicantStage @default(INBOX)
  stageChangedAt  DateTime       @default(now())
  privacyAccepted Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  job       Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  documents Document[]
  notes     Note[]
  emails    EmailLog[]

  @@index([jobId, stage])
  @@map("applicants")
}

enum ApplicantStage {
  INBOX      // Eingang
  INTERVIEW  // Interview
  OFFER      // Angebot
  REJECTED   // Abgelehnt
}

// --- Documents (Lebenslauf, Anschreiben) ---

model Document {
  id          String   @id @default(cuid())
  applicantId String
  name        String
  url         String
  mimeType    String
  sizeBytes   Int
  createdAt   DateTime @default(now())

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@map("documents")
}

// --- Notes (Notizen) ---

model Note {
  id          String   @id @default(cuid())
  applicantId String
  authorId    String   // Clerk user ID
  authorName  String
  body        String   @db.Text
  createdAt   DateTime @default(now())

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@map("notes")
}

// --- Email Templates & Logs ---

model EmailTemplate {
  id        String        @id @default(cuid())
  orgId     String
  name      String
  subject   String
  body      String        @db.Text
  trigger   EmailTrigger?
  language  String        @default("de")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("email_templates")
}

enum EmailTrigger {
  STAGE_INTERVIEW
  STAGE_OFFER
  STAGE_REJECTED
}

model EmailLog {
  id          String   @id @default(cuid())
  applicantId String
  templateId  String?
  subject     String
  body        String   @db.Text
  sentAt      DateTime @default(now())

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@map("email_logs")
}
